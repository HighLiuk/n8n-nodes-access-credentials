{
	"name": "n8n-nodes-access-credentials",
	"version": "0.1.0",
	"description": "n8n node to access and decode credentials in the workflow",
	"keywords": [
		"n8n-community-node-package"
	],
	"license": "MIT",
	"author": {
		"name": "Luca Di Fazio"
	},
	"main": "index.js",
	"scripts": {
		"build": "tsc",
		"dev": "tsc --watch",
		"lint": "eslint src --ext .ts",
		"lintfix": "eslint src --ext .ts --fix",
		"format": "prettier src --write",
		"prepublishOnly": "npm run build && npm run lint"
	},
	"files": [
		"dist"
	],
	"n8n": {
		"n8nNodesApiVersion": 1,
		"credentials": [],
		"nodes": [
			"dist/nodes/AccessCredentials/AccessCredentials.node.js"
		]
	},
	"devDependencies": {
		"@types/node": "^20.0.0",
		"@typescript-eslint/eslint-plugin": "~8.32.0",
		"@typescript-eslint/parser": "~8.32.0",
		"eslint": "^8.57.0",
		"eslint-plugin-n8n-nodes-base": "^1.16.3",
		"n8n-workflow": "*",
		"prettier": "^3.5.3",
		"typescript": "~5.4.0"
	},
	"peerDependencies": {
		"n8n-workflow": "*"
	}
}
